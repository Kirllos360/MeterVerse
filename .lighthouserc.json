{
  "ci": {
    "collect": {
      "url": ["http://localhost:3030"],
      "numberOfRuns": 3,
      "startServerCommand": "cd Frontend/meterverse-ui && bun run build && bun run start"
    },
    "assert": {
      "assertions": {
        "first-contentful-paint": ["warn", {"minScore": 0.9}],
        "largest-contentful-paint": ["error", {"minScore": 0.8}],
        "interactive": ["error", {"minScore": 0.8}],
        "cumulative-layout-shift": ["error", {"minScore": 0.9}],
        "total-blocking-time": ["error", {"minScore": 0.8}],
        "speed-index": ["warn", {"minScore": 0.8}]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lighthouse-reports"
    }
  }
}
