<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="elec_invoice" pageWidth="421" pageHeight="297" orientation="Landscape" columnWidth="413" leftMargin="4" rightMargin="4" topMargin="5" bottomMargin="5" uuid="b3aae808-6eeb-4617-b9a8-226c81ef6df3">
	<property name="ireport.zoom" value="1.6500000000000004"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="48"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<parameter name="invoiceId" class="java.lang.Long">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="billcycleLogId" class="java.lang.Long">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
  (select project_title_ar from adm_project where id = m.project_id) as project_title,
  (select license from adm_project where id = m.project_id) as license,
  (select company_info from adm_project where id = m.project_id) as company_info,
  (select img from adm_project where id = m.project_id) logo,
  (select signature from adm_project where id = m.project_id) signature,
  i.id as invoice_id,
  i.status,
  c.code as customer_code,
  c.id as customer_id,
  c.name_ar,
  c.tenant_name,
  i.number as number,
  m.serial as meter_serial,
  t.name_en as tariff_name,
  i.counsumption_month,
  DATEADD(month, 1, i.counsumption_month) as due_date,
  i.total_amt,
  i.total_consumption,
  u.unit_no,
  u.additional_info,
  u.unit_no + ' ' + u.city as address_ar,
  (select top 1 start_reading from invoice_details where invoice_id = i.id and start_reading is not null) as start_reading,
  (select top 1 end_reading from invoice_details where invoice_id = i.id and start_reading is not null) as end_reading,
  (select top 1 consumption_value from invoice_details where invoice_id = i.id and start_reading is not null) as consumption_value,
  (select sum(amount) from invoice_details where invoice_id = i.id and charge_group='CONSUMPTION') as Cons,
  (select sum(amount) from invoice_details where invoice_id = i.id and charge_group='CUSTOMER_SERVICE') as CS,
  (select sum(amount) from invoice_details where invoice_id = i.id and charge_group='ISSUE_FEES') as Admin,
  (select sum(amount) from invoice_details where invoice_id = i.id and charge_group='FEES') as OTHER
from
  invoice i,
  meter m,
  customer c,
  tariff t,
  unit u
where
  i.meter_id = m.id
  and m.unit_id = u.id
  and m.customer_id = c.id
  and m.tariff_id = t.id
  and i.id = $P{invoiceId}]]>
	</queryString>
