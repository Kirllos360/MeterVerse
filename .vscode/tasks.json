{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Toolchain: Dependency Check",
      "type": "shell",
      "command": "depcruise src --output-type err && madge --circular src/index.ts",
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Toolchain: Security Scan",
      "type": "shell",
      "command": "semgrep --config=auto . --metrics=off && trivy fs --severity CRITICAL,HIGH .",
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Toolchain: Full Validation",
      "type": "shell",
      "command": "Invoke-ToolchainCheck",
      "problemMatcher": [],
      "group": "test"
    },
    {
