      "group": "test"
    },
    {
      "label": "Enterprise: Full Certification",
      "type": "shell",
      "command": "npx tsc --noEmit && eslint . --ext .ts,.tsx && depcruise src --output-type err && madge --circular src/index.ts && knip && ts-prune",
