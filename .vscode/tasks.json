      "description": "Search pattern for ast-grep"
    },
    {
      "id": "configFile",
      "type": "promptString",
      "description": "Path to style-dictionary config"
    },
    {
      "id": "url",
      "type": "promptString",
      "description": "URL to test for accessibility"
    },
    {
      "id": "specFile",
      "type": "promptString",
      "description": "API spec file to lint",
      "default": "openapi.yaml"
    }
  ]
}
