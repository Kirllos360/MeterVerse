generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  AREA_MANAGER
  OPERATOR
  TECHNICIAN
  FINANCE
  SUPPORT
  CUSTOMER
}

enum MeterType {
  ELECTRICITY
  WATER
  SOLAR
  GAS
  CHILLED_WATER
  OUTDOOR_UNIT
}

enum MeterStatus {
  AVAILABLE
  ASSIGNED
  ACTIVE
  OFFLINE
  FAULTY
  REPLACED
  TERMINATED
  RETIRED
}

enum ReadingStatus {
  PENDING
  VALID
  SUSPICIOUS
  CORRECTED
  REJECTED
  APPROVED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REVERSED
}

// ======================== CORE ========================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nameAr    String
  nameEn    String?
  phone     String?
  role      UserRole @default(OPERATOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers   Customer[]
  readings    Reading[]
  invoices    Invoice[]
  payments    Payment[]
  auditLogs   AuditLog[]
  refreshToken RefreshToken?
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ======================== CUSTOMER ========================

model Customer {
  id        String   @id @default(cuid())
  code      String   @unique
  nameAr    String
  nameEn    String?
  phone     String
  email     String?
  type      String   @default("residential")
  status    String   @default("active")
  balance   Float    @default(0)
  address   String?
  projectId String
  unitId    String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meters        Meter[]
  readings      Reading[]
  invoices      Invoice[]
  payments      Payment[]
  ledgerEntries LedgerEntry[]
  wallet        Wallet?
}

// ======================== PROJECT / UNIT ========================

model Project {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  area      String
  status    String   @default("active")
  createdAt DateTime @default(now())

  customers Customer[]
  meters    Meter[]
  invoices  Invoice[]
}

model Unit {
  id        String   @id @default(cuid())
  name      String
  code      String
  type      String
  status    String   @default("vacant")
  area      Float?
  projectId String
  floorId   String?
  createdAt DateTime @default(now())

  customers Customer[]
  meters    Meter[]
}

// ======================== METER ========================

model Meter {
  id               String     @id @default(cuid())
  serialNumber     String     @unique
  type             MeterType  @default(ELECTRICITY)
  brand            String?
  model            String?
  status           MeterStatus @default(AVAILABLE)
  location         String?
  installationDate DateTime?
  lastReading      Float?
  lastReadingDate  DateTime?
  communicationType String?
  firmware         String?
  battery          Float?
  signalQuality    Int?
  customerId       String?
  customer         Customer?  @relation(fields: [customerId], references: [id])
  unitId           String?
  unit             Unit?      @relation(fields: [unitId], references: [id])
  projectId        String
  project          Project    @relation(fields: [projectId], references: [id])
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  readings  Reading[]
  simCard   SimCard?
}

model SimCard {
  id          String   @id @default(cuid())
  iccid       String   @unique
  msisdn      String?
  provider    String?
  status      String   @default("available")
  cooldownUntil DateTime?
  meterId     String?  @unique
  meter       Meter?   @relation(fields: [meterId], references: [id])
  createdAt   DateTime @default(now())
}

// ======================== READING ========================

model Reading {
  id            String        @id @default(cuid())
  meterId       String
  meter         Meter         @relation(fields: [meterId], references: [id])
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id])
  previousValue Float
  currentValue  Float
  consumption   Float
  date          DateTime
  source        String        @default("manual")
  status        ReadingStatus @default(PENDING)
  notes         String?
  enteredById   String?
  enteredBy     User?         @relation(fields: [enteredById], references: [id])
  createdAt     DateTime      @default(now())

  review ReadingReview?
}

model ReadingReview {
  id        String   @id @default(cuid())
  readingId String   @unique
  reading   Reading  @relation(fields: [readingId], references: [id])
  action    String
  reason    String?
  reviewerId String
  createdAt DateTime @default(now())
}

// ======================== INVOICE ========================

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id])
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id])
  period      String
  issueDate   DateTime
  dueDate     DateTime
  total       Float
  paid        Float         @default(0)
  outstanding Float         @default(0)
  status      InvoiceStatus @default(DRAFT)
  notes       String?
  createdById String?
  createdBy   User?         @relation(fields: [createdById], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lines     InvoiceLine[]
  payments  Payment[]
  ledger    LedgerEntry[]
}

model InvoiceLine {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  description String
  quantity  Float   @default(1)
  unitPrice Float
  total     Float
  type      String  @default("consumption")
}

// ======================== PAYMENT ========================

model Payment {
  id         String        @id @default(cuid())
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  invoiceId  String?
  invoice    Invoice?      @relation(fields: [invoiceId], references: [id])
  amount     Float
  method     String        @default("cash")
  date       DateTime
  reference  String?
  status     PaymentStatus @default(COMPLETED)
  notes      String?
  createdById String?
  createdBy  User?         @relation(fields: [createdById], references: [id])
  createdAt  DateTime      @default(now())
}

// ======================== LEDGER ========================

model LedgerEntry {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  date       DateTime
  description String
  debit      Float    @default(0)
  credit     Float    @default(0)
  balance    Float
  reference  String?
  category   String
  invoiceId  String?
  invoice    Invoice? @relation(fields: [invoiceId], references: [id])
  createdAt  DateTime @default(now())
}

// ======================== WALLET ========================

model Wallet {
  id         String   @id @default(cuid())
  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id])
  balance    Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ======================== TARIFF ========================

model Tariff {
  id           String   @id @default(cuid())
  name         String
  type         MeterType
  chargeMode   String   @default("PER_UNIT")
  rate         Float
  fixedCharge  Float    @default(0)
  tax          Float    @default(0)
  effectiveFrom DateTime
  effectiveTo  DateTime?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  slabs TariffSlab[]
}

model TariffSlab {
  id       String @id @default(cuid())
  tariffId String
  tariff   Tariff @relation(fields: [tariffId], references: [id])
  fromUsage Float
  toUsage   Float?
  rate      Float
}

// ======================== AUDIT ========================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entity     String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
}
