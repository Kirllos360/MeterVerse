{
    "name": "meterverse-backend",
    "version": "8.0.0",
    "type": "module",
    "scripts": {
        "dev": "node src/server.js",
        "start": "node src/server.js",
        "db:generate": "npx prisma generate",
        "db:push": "npx prisma db push",
        "db:seed": "node scripts/seed.js",
        "test": "vitest run",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:coverage": "vitest run --coverage",
        "db:setup": "npm run db:generate && npx prisma db push && npm run db:seed"
    },
    "dependencies": {
        "@prisma/client": "^6.0.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "express": "^4.21.0",
        "express-rate-limit": "^7.5.0",
        "helmet": "^8.0.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.2.0",
        "nodemailer": "^9.0.3",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "speakeasy": "^2.0.0",
        "xlsx": "^0.18.5",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^4.1.10",
        "prisma": "^6.0.0",
        "supertest": "^7.2.2",
        "vitest": "^4.1.10"
    }
}
