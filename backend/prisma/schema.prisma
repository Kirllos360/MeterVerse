generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  name         String
  role         String        @default("viewer")
  avatar       String?
  phone        String?
  status       String        @default("active")
  emailVerified Boolean      @default(false)
  area         String        @default("")
  project      String        @default("")
  tenant       String        @default("")
  language     String        @default("en")
  theme        String        @default("adaptive")
  mfaEnabled   Boolean       @default(false)
  lastActiveAt DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     Session[]
  apiKeys      ApiKey[]
  auditEntries AuditEntry[]
  roleId       String?
  roleRel      Role?         @relation(fields: [roleId], references: [id])
}

model Role {
  id          String             @id @default(uuid())
  name        String             @unique
  description String?
  isSystem    Boolean            @default(false)
  permissions PermissionOnRole[]
  users       User[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model Permission {
  id          String             @id @default(uuid())
  name        String             @unique
  description String?
  module      String
  roles       PermissionOnRole[]
  createdAt   DateTime           @default(now())
}

model PermissionOnRole {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
}

model AuditEntry {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  actor     String?
  actorId   String?
  action    String
  resource  String?
  resourceId String?
  details   String?
  ip        String?
  userAgent String?
  status    String   @default("success")
  user      User?    @relation(fields: [actorId], references: [id])
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  category  String   @default("general")
  type      String   @default("string")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeatureFlag {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  enabled   Boolean  @default(false)
  scope     String   @default("global")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id        String   @id @default(uuid())
  name      String
  key       String   @unique
  prefix    String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  permissions String  @default("read")
  lastUsedAt DateTime?
  expiresAt DateTime?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ip        String?
  userAgent String?
  device    String?
  location  String?
  isActive  Boolean  @default(true)
  lastUsedAt DateTime @default(now())
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Organization {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  domain    String?
  logo      String?
  plan      String    @default("free")
  status    String    @default("active")
  settings  String    @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
}

model Project {
  id             String       @id @default(uuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  status         String       @default("active")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Webhook {
  id        String   @id @default(uuid())
  name      String
  url       String
  events    String   @default("[]")
  secret    String?
  active    Boolean  @default(true)
  lastTriggeredAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationTemplate {
  id      String @id @default(uuid())
  key     String @unique
  name    String
  type    String @default("email")
  subject String?
  body    String
  variables String @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Backup {
  id        String   @id @default(uuid())
  name      String
  type      String   @default("full")
  size      String?
  status    String   @default("pending")
  path      String?
  startedAt DateTime?
  completedAt DateTime?
  createdAt DateTime @default(now())
}

model CacheEntry {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  ttl       Int?
  hits      Int      @default(0)
  createdAt DateTime @default(now())
  expiresAt DateTime?
}

model QueueJob {
  id        String   @id @default(uuid())
  type      String
  payload   String   @default("{}")
  status    String   @default("pending")
  priority  Int      @default(0)
  attempts  Int      @default(0)
  maxAttempts Int    @default(3)
  error     String?
  scheduledAt DateTime?
  startedAt DateTime?
  completedAt DateTime?
  createdAt DateTime @default(now())
}

model ScheduledTask {
  id           String   @id @default(uuid())
  name         String
  description  String?
  cron         String
  taskType     String
  config       String   @default("{}")
  active       Boolean  @default(true)
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StoredFile {
  id          String   @id @default(uuid())
  name        String
  originalName String
  mimeType    String
  size        Int
  path        String
  category    String   @default("general")
  uploadedBy  String?
  createdAt   DateTime @default(now())
}

model License {
  id          String   @id @default(uuid())
  key         String   @unique
  type        String   @default("enterprise")
  status      String   @default("active")
  seats       Int      @default(1)
  expiresAt   DateTime?
  activatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BrandingConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  category  String   @default("general")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  type      String   @default("in_app")
  title     String
  body      String
  recipientId String?
  recipientEmail String?
  status    String   @default("pending")
  channel   String   @default("in_app")
  sentAt    DateTime?
  readAt    DateTime?
  error     String?
  createdAt DateTime @default(now())
}

model ActivityStream {
  id        String   @id @default(uuid())
  actor     String?
  actorId   String?
  action    String
  resource  String?
  resourceId String?
  details   String?
  ip        String?
  severity  String   @default("info")
  createdAt DateTime @default(now())
}

model EmailLog {
  id        String   @id @default(uuid())
  to        String
  from      String
  subject   String
  body      String?
  status    String   @default("pending")
  error     String?
  sentAt    DateTime?
  createdAt DateTime @default(now())
}

model SmsLog {
  id        String   @id @default(uuid())
  to        String
  from      String?
  message   String
  status    String   @default("pending")
  error     String?
  sentAt    DateTime?
  createdAt DateTime @default(now())
}

model ImportJob {
  id          String   @id @default(uuid())
  type        String
  fileName    String?
  status      String   @default("pending")
  totalRows   Int      @default(0)
  processed   Int      @default(0)
  failed      Int      @default(0)
  errors      String?
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

model ExportJob {
  id          String   @id @default(uuid())
  type        String
  format      String   @default("csv")
  filters     String   @default("{}")
  status      String   @default("pending")
  totalRows   Int      @default(0)
  filePath    String?
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

model PushNotification {
  id        String   @id @default(uuid())
  title     String
  body      String
  deviceToken String?
  platform  String   @default("all")
  status    String   @default("pending")
  sentAt    DateTime?
  error     String?
  createdAt DateTime @default(now())
}

model OcrJob {
  id        String   @id @default(uuid())
  fileName  String
  status    String   @default("pending")
  result    String?
  confidence Float?
  processedAt DateTime?
  createdAt DateTime @default(now())
}

model PdfJob {
  id        String   @id @default(uuid())
  type      String   @default("report")
  template  String?
  data      String   @default("{}")
  status    String   @default("pending")
  filePath  String?
  createdAt DateTime @default(now())
  completedAt DateTime?
}

model ExcelJob {
  id        String   @id @default(uuid())
  type      String   @default("export")
  format    String   @default("xlsx")
  data      String   @default("{}")
  status    String   @default("pending")
  filePath  String?
  totalRows Int      @default(0)
  createdAt DateTime @default(now())
  completedAt DateTime?
}

model ReportDefinition {
  id          String   @id @default(uuid())
  name        String
  type        String   @default("operational")
  description String?
  config      String   @default("{}")
  schedule    String?
  recipients  String?
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KpiDefinition {
  id          String   @id @default(uuid())
  name        String
  category    String   @default("operations")
  target      Float?
  unit        String   @default("count")
  current     Float?
  trend       String   @default("stable")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KpiSnapshot {
  id          String   @id @default(uuid())
  kpiId       String
  kpi         KpiDefinition @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  value       Float
  recordedAt  DateTime @default(now())
}

model ScheduledReport {
  id          String   @id @default(uuid())
  name        String
  reportType  String
  schedule    String   @default("daily")
  format      String   @default("pdf")
  recipients  String?
  active      Boolean  @default(true)
  lastSentAt  DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExportLog {
  id          String   @id @default(uuid())
  type        String
  format      String   @default("csv")
  filters     String   @default("{}")
  totalRows   Int      @default(0)
  filePath    String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  completedAt DateTime?
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  status    String   @default("active")
  area      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  meters    Meter[]
  invoices  Invoice[]
}

model Meter {
  id        String   @id @default(uuid())
  serial    String   @unique
  type      String
  location  String?
  status    String   @default("active")
  area      String?
  customerId String?
  customer  Customer? @relation(fields: [customerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  readings  Reading[]
}

model Reading {
  id        String   @id @default(uuid())
  meterId   String
  meter     Meter    @relation(fields: [meterId], references: [id])
  value     Float
  unit      String   @default("kWh")
  timestamp DateTime @default(now())
  source    String   @default("manual")
  status    String   @default("valid")
  createdAt DateTime @default(now())
}

model Invoice {
  id         String   @id @default(uuid())
  number     String   @unique
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  amount     Float
  status     String   @default("pending")
  dueDate    DateTime?
  issuedAt   DateTime @default(now())
  paidAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  payments   Payment[]
}

model Payment {
  id        String   @id @default(uuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  amount    Float
  method    String   @default("cash")
  status    String   @default("completed")
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())
}
