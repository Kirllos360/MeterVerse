{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    ".opencode/plugins/graphify.js"
  ],
  "mcp": {
    "notion": {
      "type": "local",
      "command": ["npx", "-y", "@notionhq/notion-mcp-server"],
      "enabled": true,
      "env": {
        "NOTION_TOKEN": "ntn_xxxxxxxxxxxxxxxxxxxxxx"
      }
    },
    "odoo": {
      "type": "local",
      "command": ["npx", "-y", "@mweinheimer/odoo-mcp-server", "--stdio"],
      "enabled": true,
      "env": {
        "ODOO_URL": "http://your-odoo-instance:8069",
        "ODOO_DB": "your_database_name",
        "ODOO_USERNAME": "your_username",
        "ODOO_PASSWORD": "your_password"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "env": {
        "CONTEXT7_API_KEY": ""
      }
    },
    "figma-context": {
      "type": "local",
      "command": ["npx", "-y", "figma-developer-mcp", "--stdio"],
      "enabled": true,
      "env": {
        "FIGMA_API_KEY": ""
      }
    },
    "serena": {
      "type": "local",
      "command": ["uvx", "serena-agent", "start-mcp-server", "--project-from-cwd"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp"],
      "enabled": true
    },
    "codebase-memory": {
      "type": "local",
      "command": ["npx", "-y", "codebase-memory-mcp"],
      "enabled": true
    },
    "ast-grep": {
      "type": "local",
      "command": ["sg", "--mcp"],
      "enabled": false,
      "description": "Semantic code search and structural AST analysis"
    },
    "storybook-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@storybook/mcp"],
      "enabled": true,
      "description": "Storybook project analysis via MCP"
    },
    "spectral": {
      "type": "local",
      "command": ["spectral", "--help"],
      "enabled": false,
      "description": "OpenAPI/AsyncAPI contract validation"
    }
  }
}